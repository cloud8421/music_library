{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "lib": ["ES2022"]
  },
  "include": ["ci-client.ts", "format.ts", "index.ts", "*.test.ts"],
  "exclude": ["node_modules"]
}

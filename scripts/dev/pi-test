#!/usr/bin/env bash

#MISE description="Run pi tests"

set -e

source "$(git rev-parse --show-toplevel)/scripts/_helpers.sh"

ensure_working_directory!

run_npm_extension_tests() {
  local extension_dir="$1"

  if [[ -f "$extension_dir/package-lock.json" && ! -d "$extension_dir/node_modules" ]]; then
    npm ci --prefix "$extension_dir"
  fi

  npm test --prefix "$extension_dir"
}

run_npm_extension_tests .pi/extensions/sensitive-file-guard

run_npm_extension_tests .pi/extensions/s3-browser

run_npm_extension_tests .pi/extensions/ci-browser

run_npm_extension_tests .pi/extensions/prod-metrics
